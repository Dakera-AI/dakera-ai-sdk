{
  "name": "@dakera-ai/ai-sdk",
  "version": "0.1.0",
  "description": "Vercel AI SDK integration for Dakera AI memory — persistent, decay-weighted cross-session memory via language model middleware and tools",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vercel",
    "ai-sdk",
    "ai",
    "dakera",
    "memory",
    "middleware",
    "tools",
    "rag",
    "agents",
    "typescript"
  ],
  "author": "Dakera Team",
  "license": "MIT",
  "homepage": "https://github.com/dakera-ai/dakera-ai-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/dakera-ai/dakera-ai-sdk"
  },
  "bugs": {
    "url": "https://github.com/dakera-ai/dakera-ai-sdk/issues"
  },
  "peerDependencies": {
    "@dakera-ai/dakera": ">=0.11.54",
    "ai": ">=6.0.0",
    "zod": ">=3.23.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^4.0.1",
    "@dakera-ai/dakera": "^0.11.100",
    "@types/node": "^25.7.0",
    "ai": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
